# ====================
# TERRAFORM
# ====================

# Local .terraform directories
**/.terraform/*

# .terraform.lock.hcl MUST be committed (standardizes provider versions)
!**/.terraform.lock.hcl

# .tfstate files (NEVER commit - contains secrets!)
**/terraform.tfstate
**/terraform.tfstate.*
**/crash.log
**/crash.*.log

# Exclude all .tfvars files, which might contain sensitive data
**/terraform.tfvars
**/terraform.tfvars.json

# Ignore override files
**/override.tf
**/override.tf.json
**/override_files/
**/terraform_override.tf
**/terraform_override.tf.json

# Ignore CLI configuration files
**/.terraformrc

# Ignore plan files
**/*.tfplan

# Local .env files (may contain secrets)
**/.env
**/.env.local
**/.env.*.local

# ====================
# DOCKER
# ====================

.docker/
.dockerignore
docker-compose.override.yml

